<div class="editor-page">
  <h1>Map Editor</h1>
  <div class="map-list">
    <% @maps.each do |map| %>
      <a href="<%= editor_map_path(map) %>" class="map-card">
        <span class="map-name"><%= map.name %></span>
        <span class="map-info"><%= map.width %>x<%= map.height %> - <%= map.tileset %></span>
      </a>
    <% end %>
  </div>
  <button id="create-map-btn">+ New Map</button>
</div>

<style>
  .editor-page {
    padding: 32px;
    max-width: 800px;
    margin: 0 auto;
  }
  .editor-page h1 {
    color: #d4a855;
    font-size: 24px;
    margin-bottom: 24px;
    text-transform: uppercase;
    letter-spacing: 4px;
  }
  .map-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 24px;
  }
  .map-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    background: #1a1008;
    border: 1px solid #6b4c2a;
    color: #c4a882;
    text-decoration: none;
    font-family: inherit;
  }
  .map-card:hover {
    border-color: #d4a855;
    background: #231608;
  }
  .map-name { color: #d4a855; }
  .map-info { color: #8b7355; font-size: 12px; }
  #create-map-btn {
    padding: 10px 24px;
    background: #6b4c2a;
    border: 1px solid #d4a855;
    color: #d4a855;
    font-family: inherit;
    font-size: 14px;
    cursor: pointer;
    text-transform: uppercase;
  }
  #create-map-btn:hover { background: #8b6340; }
</style>

<script>
  document.getElementById("create-map-btn").addEventListener("click", async () => {
    const name = prompt("Map name:");
    if (!name) return;
    const res = await fetch("/api/maps", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ name, width: 32, height: 32, spawn_x: 16, spawn_y: 16, tileset: "church_dungeon" }),
    });
    if (res.ok) {
      const map = await res.json();
      window.location.href = `/editor/${map.id}`;
    } else {
      const err = await res.json();
      alert(err.errors?.join(", ") || "Error creating map");
    }
  });
</script>
