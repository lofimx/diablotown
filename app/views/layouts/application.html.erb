<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "DiabloTown" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="DiabloTown">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <% og_image = "#{request.base_url}/diablo-town-logo.png" %>
    <meta property="og:title" content="DiabloTown">
    <meta property="og:description" content="It's Gather Town... but Diablo. Yes, it's very stupid.">
    <meta property="og:image" content="<%= og_image %>">
    <meta property="og:image:width" content="1424">
    <meta property="og:image:height" content="752">
    <meta property="og:image:type" content="image/png">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="DiabloTown">
    <meta name="twitter:description" content="It's Gather Town... but Diablo. Yes, it's very stupid.">
    <meta name="twitter:image" content="<%= og_image %>">

    <%= vite_client_tag %>
    <%= vite_typescript_tag "application" %>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
